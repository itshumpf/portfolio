---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CsiShowcase from '../components/CsiShowcase.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Footer from '../components/Footer.astro';

const [profile] = await getCollection('profile');
---

<BaseLayout
  title="Braeden Keena"
  description="Full-stack builder with an IoT/firmware background — a decade of operations leadership behind eighteen months of self-taught engineering, including a 99.6%-accurate WiFi-CSI RF-fingerprinting sensor array."
>
  <Hero profile={profile} />
  <CsiShowcase />
  <About profile={profile} />
  <Projects />
  <Footer profile={profile} />
</BaseLayout>