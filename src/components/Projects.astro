---
import { getCollection, render } from 'astro:content';
import CaseImage from './CaseImage.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  projects.map(async (project) => ({
    project,
    Content: project.data.expandedBody ? (await render(project)).Content : null,
  })),
);

const statusLabel: Record<string, string> = {
  live: 'Live',
  sunset: 'Sunset',
  wip: 'In progress',
};
---

<section id="work">
  <div class="wrap">
    <p class="eyebrow">Other work</p>
    <h2 class="section-title">Selected work.</h2>

    <div class="project-list">
      {
        rendered.map(({ project, Content }) => (
          <article class="project">
            <div class="project__head">
              <h3>{project.data.title}</h3>
              <span class="project__meta">
                {statusLabel[project.data.status]} · {project.data.period}
              </span>
            </div>
            {Content ? (
              <div class="project__body">
                <Content />
              </div>
            ) : (
              <p class="project__tagline">{project.data.tagline}</p>
            )}
            {project.data.screenshots && project.data.screenshots.length > 0 && (
              <div class="project__shots">
                {project.data.screenshots.map((shot) => (
                  <CaseImage image={shot} />
                ))}
              </div>
            )}
            <p class="tag-list project__tech">{project.data.tech.join(' · ')}</p>
            {project.data.links.live && (
              <a class="text-link" href={project.data.links.live} target="_blank" rel="noopener noreferrer">
                {project.data.links.live.replace(/^https?:\/\//, '')}
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .project-list {
    display: grid;
    gap: 0;
  }

  .project {
    padding-block: 28px;
    border-top: 1px solid var(--border-soft);
  }

  .project:last-child {
    border-bottom: 1px solid var(--border-soft);
  }

  .project__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .project__head h3 {
    font-size: 1.05rem;
  }

  .project__meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .project__tagline {
    color: var(--text-secondary);
    font-size: 0.95rem;
    max-width: 62ch;
    margin-bottom: 12px;
  }

  .project__body {
    color: var(--text-secondary);
    font-size: 0.95rem;
    max-width: 68ch;
  }

  .project__body :global(p) {
    margin-bottom: 12px;
  }

  .project__body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Screenshots sit between the prose and the tech list. Single column so
     wide captures stay legible — side by side they'd shrink below the point
     where the pricing tables can be read. */
  .project__shots {
    display: grid;
    gap: 16px;
    margin-block: 18px;
    max-width: 68ch;
  }

  .project__tech {
    margin-bottom: 12px;
  }
</style>
