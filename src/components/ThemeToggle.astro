---
import '../styles/party.css';
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  title="Toggle theme"
>
  <svg class="icon icon--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <circle cx="12" cy="12" r="4.2" />
    <path d="M12 2.5v2.4M12 19.1v2.4M4.2 4.2l1.7 1.7M18.1 18.1l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.2 19.8l1.7-1.7M18.1 5.9l1.7-1.7" stroke-linecap="round" />
  </svg>
  <svg class="icon icon--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a6.8 6.8 0 0 0 10.5 10.5Z" stroke-linejoin="round" />
  </svg>
</button>

<div id="party-modal" class="party-modal" hidden>
  <div class="party-modal__backdrop" data-party-close></div>
  <div class="party-modal__box" role="dialog" aria-modal="true" aria-labelledby="party-modal-title">
    <p id="party-modal-title" class="party-modal__title">You found it.</p>
    <p class="party-modal__sub">Proceed at your own risk.</p>
    <button id="party-enter" class="party-modal__enter" type="button">ENTER PARTY MODE</button>
    <button class="party-modal__cancel" type="button" data-party-close>never mind</button>
  </div>
</div>

<div id="party-marquee" class="party-marquee" hidden>
  <div class="party-marquee__track">
    <span>🎉 YOU ARE NOW IN PARTY MODE 🎉 &nbsp; · &nbsp; WELCOME TO THE INTERNET CIRCA 2005 &nbsp; · &nbsp; SIGN MY GUESTBOOK &nbsp; · &nbsp; BEST VIEWED IN 800×600 &nbsp; · &nbsp; 🦄 THANKS FOR VISITING 🦄 &nbsp; · &nbsp; </span>
    <span aria-hidden="true">🎉 YOU ARE NOW IN PARTY MODE 🎉 &nbsp; · &nbsp; WELCOME TO THE INTERNET CIRCA 2005 &nbsp; · &nbsp; SIGN MY GUESTBOOK &nbsp; · &nbsp; BEST VIEWED IN 800×600 &nbsp; · &nbsp; 🦄 THANKS FOR VISITING 🦄 &nbsp; · &nbsp; </span>
  </div>
</div>

<button id="party-exit" class="party-exit" type="button" hidden>✖ Exit Party Mode</button>

<script>
  const root = document.documentElement;
  const toggle = document.getElementById('theme-toggle');
  const modal = document.getElementById('party-modal');
  const enterBtn = document.getElementById('party-enter');
  const exitBtn = document.getElementById('party-exit');
  const marquee = document.getElementById('party-marquee');

  function setTheme(theme: 'light' | 'dark') {
    root.setAttribute('data-theme', theme);
    try {
      localStorage.setItem('theme', theme);
    } catch {
      /* private browsing / storage disabled — theme just won't persist */
    }
  }

  toggle?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
    setTheme(current === 'light' ? 'dark' : 'light');
  });

  function openModal() {
    if (modal) modal.hidden = false;
  }

  function closeModal() {
    if (modal) modal.hidden = true;
  }

  toggle?.addEventListener('dblclick', (event) => {
    event.preventDefault();
    openModal();
  });

  modal?.querySelectorAll('[data-party-close]').forEach((el) => {
    el.addEventListener('click', closeModal);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal && !modal.hidden) closeModal();
  });

  const SPARKLES = ['✨', '⭐', '💖', '🌈', '💫', '🔥', '👽', '🦄', '🌟'];
  let trailHandler: ((event: PointerEvent) => void) | null = null;

  function startCursorTrail() {
    let last = 0;
    trailHandler = (event: PointerEvent) => {
      const now = performance.now();
      if (now - last < 45) return;
      last = now;
      const el = document.createElement('span');
      el.className = 'party-sparkle';
      el.textContent = SPARKLES[Math.floor(Math.random() * SPARKLES.length)];
      el.style.left = `${event.clientX}px`;
      el.style.top = `${event.clientY}px`;
      document.body.appendChild(el);
      el.addEventListener('animationend', () => el.remove());
    };
    document.addEventListener('pointermove', trailHandler);
  }

  function stopCursorTrail() {
    if (trailHandler) document.removeEventListener('pointermove', trailHandler);
    trailHandler = null;
    document.querySelectorAll('.party-sparkle').forEach((el) => el.remove());
  }

  function enterParty() {
    root.classList.add('party-mode');
    if (exitBtn) exitBtn.hidden = false;
    if (marquee) marquee.hidden = false;
    closeModal();
    startCursorTrail();
  }

  function exitParty() {
    root.classList.remove('party-mode');
    if (exitBtn) exitBtn.hidden = true;
    if (marquee) marquee.hidden = true;
    stopCursorTrail();
  }

  enterBtn?.addEventListener('click', enterParty);
  exitBtn?.addEventListener('click', exitParty);
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .icon {
    width: 16px;
    height: 16px;
  }

  .icon--moon {
    display: none;
  }

  :global([data-theme='light']) .icon--sun {
    display: none;
  }

  :global([data-theme='light']) .icon--moon {
    display: block;
  }

  /* ---------------------------------------------------------------------
     Party mode modal — normal-site styling, matches the restrained design
     language even though what it triggers is anything but.
     ------------------------------------------------------------------- */
  /* display:none by default, independent of the browser's [hidden] UA rule
     (which a same-specificity class rule can otherwise beat on source
     order) — this must never render before its JS trigger fires. */
  .party-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 999;
    align-items: center;
    justify-content: center;
  }

  .party-modal:not([hidden]) {
    display: flex;
  }

  .party-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }

  .party-modal__box {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 32px 36px;
    text-align: center;
    max-width: 320px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .party-modal__title {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 6px;
  }

  .party-modal__sub {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 20px;
  }

  .party-modal__enter {
    display: block;
    width: 100%;
    padding: 12px 16px;
    border-radius: 6px;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: 0.02em;
    cursor: pointer;
    margin-bottom: 12px;
    transition: transform 0.1s ease, filter 0.15s ease;
  }

  .party-modal__enter:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .party-modal__cancel {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 0.82rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .party-exit {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 1001;
    padding: 10px 16px;
    border-radius: 999px;
    border: 2px solid #fff;
    background: #000;
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
  }
</style>
