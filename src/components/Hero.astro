---
import type { CollectionEntry } from 'astro:content';
import { navLinks } from '../lib/nav';
// Carries the theme switch AND party mode (it imports party.css). The
// one-page consolidation dropped the shared Nav component from the
// homepage, which silently took party mode with it — it only survived on
// /leadership, which still renders Nav. Keep this mounted here.
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  profile: CollectionEntry<'profile'>;
}

const { profile } = Astro.props;
const { name, claim, oneLiner, status, email, resumeUrl, links, ctas } = profile.data;
const activeLinks = links.filter((l) => l.url);

// Path logic for the navigation links
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<section class="hero">
  <div class="wrap wrap--wide">
    <div class="hero__ident">
      <p class="hero__name">{name}</p>
      {
        status && (
          <p class="hero__status">
            <span class="hero__status-dot" aria-hidden="true" />
            Currently: {status}
          </p>
        )
      }
    </div>

    <h1 class="hero__claim">{claim}</h1>
    <p class="hero__line">{oneLiner}</p>

    {
      ctas.length > 0 && (
        <div class="hero__ctas">
          {ctas.map((cta) => (
            <a class="btn" href={cta.href}>
              {cta.label}
            </a>
          ))}
        </div>
      )
    }

    <div class="hero__links">
      {
        activeLinks.map((link) => (
          <a class="text-link" href={link.url} target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))
      }
      <a class="text-link" href={`mailto:${email}`}>
        Email
      </a>
      {resumeUrl && (
        <a class="text-link" href={resumeUrl} download>
          Resume
        </a>
      )}
    </div>

    <nav class="hero__nav" aria-label="Secondary">
      <ul class="hero__nav-list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} aria-current={link.href === path ? 'page' : undefined}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </nav>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(64px, 10vw, 108px);
    padding-bottom: clamp(40px, 6vw, 64px);
  }

  /* The name is a quiet label; the claim below it is the largest type on
     the site. Hierarchy and spacing carry the hero — there is deliberately
     no motion here of any kind. */
  .hero__ident {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px 20px;
    margin-bottom: clamp(20px, 3vw, 30px);
  }

  .hero__name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    color: var(--text-primary);
    font-weight: 600;
  }

  .hero__status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--text-muted);
  }

  .hero__status-dot {
    width: 6px;
    height: 6px;
    flex: none;
    border-radius: 50%;
    background: var(--accent);
  }

  .hero__claim {
    font-size: clamp(2rem, 5.2vw, 3.05rem);
    line-height: 1.08;
    letter-spacing: -0.028em;
    max-width: 21ch;
    text-wrap: balance;
    margin-bottom: clamp(20px, 3vw, 28px);
  }

  .hero__line {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 56ch;
    margin-bottom: 28px;
  }

  /* The two primary destinations. `.btn` is the site's single bordered,
     unfilled button style — deliberately not a coloured marketing CTA, and
     like everything else here it has no motion beyond the colour change on
     hover that every link already has. */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
  }

  /* Both labels are full sentences, so at narrow widths they have to wrap
     inside the border rather than force the button past the viewport.
     `.btn` centres its content vertically for single-line labels; once the
     text wraps, left-align it so the second line starts under the first. */
  .hero__ctas .btn {
    text-align: left;
    max-width: 100%;
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    font-size: 0.92rem;
  }

  /* Navigation styling */
  /* Nav links and the theme/party control share one row and wrap together
     on narrow screens rather than the control being pushed off-screen. */
  .hero__nav {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 20px;
  }

  .hero__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hero__nav-list a {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.15s ease;
  }

  .hero__nav-list a:hover,
  .hero__nav-list a[aria-current='page'] {
    color: var(--text-primary);
  }
</style>